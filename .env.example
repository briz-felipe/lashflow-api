# Database
# Local dev: deixe SQLite (default)
# Docker/prod: aponta para o serviço "db" do compose
DATABASE_URL=postgresql+psycopg2://lashflow:change-me@db:5432/lashflow

# PostgreSQL — credenciais do serviço db (Docker)
POSTGRES_USER=lashflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lashflow

# JWT
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
JWT_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin user (criado no primeiro startup se não existir nenhum usuário)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=

# CORS — origens permitidas (comma-separated)
# Dev: http://localhost:3000
# Prod: https://app.seudominio.com.br
CORS_ORIGINS=http://localhost:3000

# Cookies — True em produção (exige HTTPS)
COOKIE_SECURE=False

# OAuth2 client credentials (opcional — deixe em branco para desabilitar)
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
